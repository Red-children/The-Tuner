  dialogue:
    entries:
    - id: 0
      line: "\u300C\u7B2C\u4E09\u6CE2\u5931\u8C10\u4F53\u5DF2\u6E05\u9664\u3002\u300D"
    - id: 0
      line: "\u8BE5\u533A\u57DF<b>\u5931\u8C10\u6D53\u5EA6\u5F52\u96F6</b>\u3002\u901A\u8DEF\u5C01\u9501\u89E3\u9664\u3002"
    - id: 1
      line: "\u300C\u7EC8\u4E8E\u2026\u2026\u8FD9\u6B21\u662F\u771F\u7684\u6E05\u5E72\u51C0\u4E86\u5427\uFF1F\u300D"
    - id: 0
      line: "\u300C\u5DF2\u786E\u8BA4\u3002\u524D\u65B9\u901A\u9053\u53EF\u901A\u884C\u3002\u300D"
    - id: 1
      line: "\u300C\u90A3\u8D70\u5427\uFF0C\u6211\u8981\u770B\u770B\u8C01\u5728\u641E\u4E8B\uFF01\u300D"
  speakers:
  - "\u56DE\u54CD"
  - "\u745E\u7B26"
