  dialogue:
    entries:
    - id: 1
      line: "\u300C\u95E8\u4E0D\u80FD\u4ECE\u8FD9\u4E00\u4FA7\u6253\u5F00\uFF1F\u300D"
    - id: 0
      line: "\u300C\u7B2C\u4E8C\u6CE2\u5931\u8C10\u4F53\u5DF2\u6E05\u9664\u3002\u4F46<b>\u5931\u8C10\u6D53\u5EA6\u672A\u4E0B\u964D</b>\u3002\u300D"
    - id: 1
      line: "\u300C\u8FD8\u6CA1\u5B8C\uFF1F\u300D"
    - id: 0
      line: "\u300C\u68C0\u6D4B\u5230\u7B2C\u4E09\u6CE2\u5931\u8C10\u4F53\u6B63\u5728\u751F\u6210\u3002\u300D"
    - id: 0
      line: "\u300C\u5305\u542B\u591A\u4E2A<b>\u7CBE\u82F1\u4E2A\u4F53</b>\u3002\u5A01\u80C1\u7B49\u7EA7\uFF1A\u9AD8\u3002\u300D"
    - id: 1
      line: "\u300C\u2026\u2026\u6765\u5427\uFF0C\u6211\u5F9E\u4F86\u90FD\u5514\u6703\u8F38\uFF01\u300D"
  speakers:
  - "\u56DE\u54CD"
  - "\u745E\u7B26"
