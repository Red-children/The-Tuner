  dialogue:
    entries:
    - id: 0
      line: "\u300C\u524D\u65B9\u901A\u8DEF\u5904\u4E8E\u5C01\u9501\u72B6\u6001\u3002\u68C0\u6D4B\u5230\u8C10\u5F8B\u5171\u632F\u9501\u3002\u300D"
    - id: 1
      line: "\u300C\u5171\u632F\u9501\uFF1F\u8FD9\u5565\u9634\uFF1F\u300D"
    - id: 0
      line: "\u300C\u9700\u8981\u4EE5\u6B63\u786E\u8282\u62CD\u5411\u9501\u4F53\u5C04\u51FB\u4E09\u6B21\u3002\u300D"
    - id: 0
      line: "\u300C\u8282\u62CD\u504F\u5DEE\u5C06\u5BFC\u81F4\u5171\u632F\u4E2D\u65AD\uFF0C\u9700\u91CD\u65B0\u5F00\u59CB\u3002\u300D"
    - id: 1
      line: "\u300C\u5C31\u662F\u8BF4\u2026\u2026\u8E29\u51C6\u8282\u594F\u6253\u4E09\u4E0B\u5C31\u884C\uFF1F\u300D"
    - id: 0
      line: "\u300C\u6B63\u786E\u3002\u300D"
  speakers:
  - "\u56DE\u54CD"
  - "\u745E\u7B26"
