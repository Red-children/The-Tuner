  dialogue:
    entries:
    - id: 0
      line: "\u300C\u951A\u70B9\u786E\u8BA4\uFF1A\u6821\u56ED\u97F3\u4E50\u8282\u3002<b>\u8C10\u5F8B\u72B6\u6001\u7A33\u5B9A</b>\u3002\u300D"
    - id: 0
      line: "\u300C\u4E50\u961F\u6210\u5458\u4E94\u4EBA\uFF0C\u6F14\u594F\u8F93\u51FA\u6B63\u5E38\u3002\u300D"
    - id: 1
