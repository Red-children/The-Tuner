  m_Script: {fileID: 11500000, guid: f51de2919c3d488478a2343cd233b1d7, type: 3}
  m_Name: Dialogue24
  m_EditorClassIdentifier: 
  dialogue:
    entries:
    - id: 0
      line: "\u300C\u4E34\u754C\u503C\u7A81\u7834\u3002\u951A\u70B9<b>\u5B8C\u5168\u5931\u8C10</b>\u3002\u300D"
    - id: 1
      line: "\u300C\u5979\u4EEC\u8FD8\u4F1A\u2026\u2026\u7EE7\u7EED\u7EC4\u4E50\u961F\u5417\u3002\u300D"
    - id: 0
      line: "\u300C\u6E05\u9664\u8BE5\u533A\u57DF<b>\u5931\u8C10\u4F53</b>\u540E\uFF0C\u951A\u70B9\u8C10\u5F8B\u6709\u6062\u590D\u53EF\u80FD\u3002\u300D"
    - id: 1
      line: "\u300C\u90A3\u4E9B\u5632\u7B11\u3001\u90A3\u4E9B\u5426\u5B9A\u2026\u2026\u5168\u90FD\u53D8\u6210<b>\u602A\u7269\u4E86</b>\u3002\u300D"
    - id: 1
      line: "\u300C<b>\u628A\u8FD9\u4E2A\u821E\u53F0\u8FD8\u7ED9\u5979\u4EEC#\uFF01</b>\u300D"
  speakers:
  - "\u56DE\u54CD"
  - "\u745E\u7B26"
