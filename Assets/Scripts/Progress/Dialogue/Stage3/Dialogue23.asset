  dialogue:
    entries:
    - id: 0
      line: "\u300C<b>\u8C10\u5F8B\u6C61\u67D3</b>\u6269\u6563\u4E2D\u3002\u951A\u70B9\u7A33\u5B9A\u5EA6\u6301\u7EED\u4E0B\u964D\u3002\u300D"
    - id: 1
      line: "\u300C\u90A3\u4E9B\u8BDD\u2026\u2026\u597D\u8FC7\u5206\u2026\u2026\u5979\u4EEC\u53EA\u662F\u5F39\u9519\u4E86\u4E00\u70B9\u800C\u5DF2\u2026\u2026\u300D"
    - id: 0
      line: "\u300C<b>\u8D1F\u9762\u60C5\u7EEA</b>\u6B63\u5728\u5177\u8C61\u5316\u3002\u5931\u8C10\u6D53\u5EA6\u63A5\u8FD1\u4E34\u754C\u503C\u3002\u300D"
  speakers:
  - "\u56DE\u54CD"
  - "\u745E\u7B26"
