  dialogue:
    entries:
    - id: 0
      line: "\u300C\u524D\u65B9\u68C0\u6D4B\u5230<b>\u5931\u8C10\u4F53</b>\u3002\u6570\u91CF\uFF1A\u5C11\u3002\u5A01\u80C1\u7B49\u7EA7\uFF1A\u4F4E\u3002\u300D"
    - id: 1
      line: "\u300C\u5B83\u4EEC\u628A\u8C10\u5F8B\u5168\u6405\u4E71\u4E86\u2026\u2026\u300D"
    - id: 0
      line: "\u300C\u653B\u51FB\u4E0E<b>\u8282\u62CD\u540C\u9891</b>\u65F6\uFF0C\u51C0\u5316\u6548\u7387\u6700\u9AD8\u3002\u300D"
    - id: 0
